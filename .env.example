# Example environment variables for local development
# Either set DATABASE_URL or the individual PG* variables below

# Example using DATABASE_URL (postgres://user:password@host:port/database)
# DATABASE_URL=postgres://postgres:postgres@db:5432/postgres

# Or individual settings:
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=postgres

# If your Postgres requires SSL, set PGSSLMODE=require
# PGSSLMODE=require

# App config
PORT=3000
NODE_ENV=development

